# Environment Configuration Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control

# =============================================================================
# Browser-Safe Variables (NEXT_PUBLIC_* prefix)
# =============================================================================

# Supabase URL - safe for browser exposure
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase publishable (anonymous) key - safe for browser exposure
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# =============================================================================
# Server-Only Variables (NO NEXT_PUBLIC_ prefix, NEVER expose to browser)
# =============================================================================

# Supabase service role key - SERVER ONLY
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Cloudflare R2 Configuration - SERVER ONLY
# See lib/config/env.ts for full variable documentation
R2_ACCOUNT_ID=your-r2-account-id
R2_BUCKET_NAME=your-r2-bucket-name
# R2 access credentials - see lib/config/env.ts getR2CredentialId() and getR2CredentialSecret()

# Worker Configuration - SERVER ONLY
WORKER_SHARED_SECRET=your-worker-shared-secret
WORKER_BASE_URL=http://localhost:3102

# =============================================================================
# Migration Flags (optional, defaults to false)
# =============================================================================

# Use hosted persistence instead of local filesystem (default: false)
USE_HOSTED_PERSISTENCE=false

# Use R2 for artifact storage instead of local filesystem (default: false)
USE_HOSTED_STORAGE=false

# Use Railway worker for preparation instead of in-process (default: false)
USE_HOSTED_WORKER=false
